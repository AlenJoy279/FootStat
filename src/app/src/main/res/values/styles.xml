<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="account_btn_style">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@android:color/background_light</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="row_text_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="defects_fixed">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">675dp</item>
        <item name="android:layout_marginTop">50dp</item>
        <item name="android:padding">16sp</item>
        <item name="android:scrollbarSize">25sp</item>
    </style>

    <style name="text_defects_fixed">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">0dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>