<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".models.jaime.MainActivityJ">


    <TextView
        android:id="@+id/textView7"
        android:layout_width="400dp"
        android:layout_height="50dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="100dp"
        android:text="FootStat"
        android:textAlignment="center"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView88"
        android:layout_width="400dp"
        android:layout_height="50dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="200dp"
        android:text="Thanks for using FootStat ! Click one of the buttons above to view stats or elo rankings."
        android:textAlignment="center"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/linearLayout1"
        android:layout_width="wrap_content"
        android:layout_height="75dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:orientation="horizontal" >
        <Button
            android:id="@+id/button1"
            android:textSize="9dp"
            android:layout_width="wrap_content"
            android:layout_height="75dp"
            android:text="La Liga" />
        <Button
            android:id="@+id/button2"
            android:textSize="9dp"
            android:layout_width="wrap_content"
            android:layout_height="75dp"
            android:text="Premier League" />
        <Button
            android:id="@+id/button3"
            android:textSize="9dp"
            android:layout_width="wrap_content"
            android:layout_height="75dp"
            android:text="Bundesliga" />

        <Button
            android:id="@+id/button4"
            android:layout_width="105dp"
            android:layout_height="75dp"
            android:text="ELO'S"
            android:textSize="9dp" />


    </LinearLayout>


</RelativeLayout>